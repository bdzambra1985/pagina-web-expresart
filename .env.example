# Copiar este archivo a .env y completar los valores.
# El archivo .env NUNCA debe subirse a git.

# Cadena de conexión a PostgreSQL
# Local:    DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/expresart
# Railway:  copiar desde Railway → Variables → DATABASE_URL
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/expresart

# Salt para hashing de contraseñas — generar con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXP_SALT=cambia_esto_por_un_valor_aleatorio_de_64_caracteres

# Contraseña del administrador (mínimo 12 caracteres)
EXP_ADMIN_PW=cambia_esto_por_una_contraseña_fuerte

# Cloudinary — almacenamiento de imágenes en la nube
# Obtener en: https://cloudinary.com → Dashboard
# Si no se definen, las imágenes se guardan en disco local (solo desarrollo)
CLOUDINARY_NAME=tu_cloud_name
CLOUDINARY_KEY=tu_api_key
CLOUDINARY_SECRET=tu_api_secret

# ── SRI Ecuador — Facturación electrónica ─────────────────────────
# '1' = pruebas (celcer.sri.gob.ec)  |  '2' = producción (cel.sri.gob.ec)
SRI_AMBIENTE=1

# RUC de la empresa emisora (13 dígitos)
SRI_RUC=

# Razón social y nombre comercial registrados en el SRI
SRI_RAZON_SOCIAL=EXPRESART
SRI_NOMBRE_COMERCIAL=EXPRESART

# Dirección matriz (aparece en la factura)
SRI_DIRECCION=Quito, Ecuador

# Código de establecimiento y punto de emisión (3 dígitos cada uno)
SRI_ESTAB=001
SRI_PTO_EMI=001

# Contraseña de la firma electrónica (.p12)
P12_PASSWORD=

# Alternativa a subir el archivo .p12: codificar en base64 y pegar aquí
# node -e "console.log(require('fs').readFileSync('mi-firma.p12').toString('base64'))"
# P12_BASE64=

# ── Emails (Resend) ────────────────────────────────────────────────
# Obtener API key en: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email del administrador que recibe notificaciones de pagos
NOTIFY_EMAIL=admin@tudominio.com

# Remitente de los emails. Dominio expresart.ec verificado en Resend.
# RESEND_FROM=EXPRESART <noreply@expresart.ec>

# Bandeja privacidad@expresart.ec (Resend → Inbound):
# 1. Configurar recepción del dominio expresart.ec en Resend (Inbound).
# 2. Crear un Webhook apuntando a https://expresart.ec/api/webhooks/resend-inbound
#    para el evento "email.received".
# 3. Pegar acá el secreto que Resend genera para ese webhook (empieza con whsec_).
RESEND_WEBHOOK_SECRET=

# Entorno
NODE_ENV=development
